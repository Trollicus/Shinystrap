<Page x:Class="Shinystrap.Pages.GameHistory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignWidth="695"
      d:DesignHeight="470"
      Title="AccountManager">

    <Page.Resources>

        <DataTemplate x:Key="GameHistoryTemplate">
            <ui:CardControl Margin="10,8,10,0" VerticalAlignment="Top">

                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32"
                    ClipToBounds="True"
                    Margin="0,0,12,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding ImageSource}"
                                Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}"
                           Foreground="White"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:CardControl.Header>

                <ui:Button Content="Rejoin"
                           Icon="{ui:SymbolIcon Play28}"
                           Padding="12,6"
                           CommandParameter="{Binding}" Click="JoinGame_OnClick"/>

            </ui:CardControl>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <TextBlock Text="Game History" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,18,0,0"/>
        <TextBlock Text="Checkout previously joined games" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,47,0,0"/>

        <ScrollViewer VerticalAlignment="Top"
                      Margin="10,68,10,0"
                      VerticalScrollBarVisibility="Auto" Height="352">
            <ItemsControl x:Name="HistoryPanel"
                          ItemTemplate="{StaticResource GameHistoryTemplate}" />
        </ScrollViewer>
        <ui:Button x:Name="LoginBtn" Content="Login"
            Foreground="White"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Width="113"
            Height="35"
            Margin="0,0,10,10" Click="Login_Click"/>
        <ui:Button x:Name="LogoutBtn" Content="Logout"
            Foreground="White"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Width="113"
            Height="35"
            Margin="0,0,128,10" Click="Logout_Click"/>

    </Grid>
</Page>