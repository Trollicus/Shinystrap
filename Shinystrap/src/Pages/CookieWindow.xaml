<ui:FluentWindow x:Class="Shinystrap.src.Pages.CookieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"

        Title="CookieWindow"
        Width="420"
        MaxHeight="170"
        MinHeight="170"
        MaxWidth="420"
        MinWidth="420"
        Height="170"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            x:Name="TitleBar"
            Height="32"
            CanMaximize="False"
            ForceShutdown="False"/>


        <TextBlock Text="Your Cookie:"
                       Foreground="White"
                       Margin="10,17,10,95" Grid.Row="1"/>

        <ui:TextBox x:Name="CookieBox"
                        Width="400"
                        HorizontalAlignment="Center" Margin="0,43,0,57" Grid.Row="1"/>



        <ui:Button Content="Add"
                           Width="92"
                           Click="Add_Click" Margin="221,96,0,0" Grid.Row="1" VerticalAlignment="Top"/>

        <ui:Button Content="Cancel"
                           Width="92"
                           Click="Cancel_Click" Margin="318,96,0,0" Grid.Row="1" VerticalAlignment="Top"/>



    </Grid>
</ui:FluentWindow>