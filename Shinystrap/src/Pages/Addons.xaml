<Page x:Class="Shinystrap.Pages.Addons"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignWidth="695"
      Title="Addons" Height="716">

    <Page.Resources>
        <ResourceDictionary>
            <StackPanel x:Key="DialogContent">
                <TextBlock Text="Are you sure you want to proceed?" TextWrapping="Wrap" />
                <CheckBox Content="Don't ask me again." />
            </StackPanel>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <TextBlock Text="Tracking" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,30,0,0"/>
        <TextBlock Text="Roblox Related" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,142,0,0"/>

        <ui:CardControl Margin="10,59,10,0" VerticalAlignment="Top">
            <ui:CardControl.Icon>
                <ui:SymbolIcon Symbol="EyeTracking24" />
            </ui:CardControl.Icon>

            <ui:CardControl.Header>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" >
                        <TextBlock Text="Server Location" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="When in-game, shows the server location." Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding IsActivityTrackingEnabled}" VerticalAlignment="Center" Checked="TrackServerLocation_OnChecked" Unchecked="TrackServerLocation_OnUnchecked"/>
        </ui:CardControl>

        <ui:CardControl Margin="10,171,10,0" VerticalAlignment="Top">
            <ui:CardControl.Icon>
                <ui:SymbolIcon Symbol="UninstallApp24" />
            </ui:CardControl.Icon>

            <ui:CardControl.Header>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" >
                        <TextBlock Text="Reinstall Roblox" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock  Text="Installs Roblox freshly" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </ui:CardControl.Header>

            <ui:Button Content="ReInstall" Foreground="White" Click="ReInstall_Click"/>


        </ui:CardControl>
        <ui:CardControl Margin="10,247,10,0" VerticalAlignment="Top">
            <ui:CardControl.Icon>
                <ui:SymbolIcon Symbol="BookmarkMultiple16" />
            </ui:CardControl.Icon>

            <ui:CardControl.Header>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" >
                        <TextBlock Text="Multi-Instance" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock  Text="Enables roblox to get opened by more than one account." Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch x:Name="MutexSwitch" VerticalAlignment="Center" Checked="RbxMutex_OnChecked" Unchecked="RbxMutex_OnUnchecked" />

        </ui:CardControl>
        <TextBlock Text="Discord Related" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,324,0,0"/>
        <ui:CardControl Margin="10,353,10,0" VerticalAlignment="Top">
            <ui:CardControl.Icon>
                <ui:SymbolIcon Symbol="Drafts16" />
            </ui:CardControl.Icon>

            <ui:CardControl.Header>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" >
                        <TextBlock Text="Discord Rich Presence" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock  Text="Shows on discord what you are playing." Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding IsActivityTrackingEnabled}" VerticalAlignment="Center" />

        </ui:CardControl>

    </Grid>
</Page>
