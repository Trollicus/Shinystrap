<Page x:Class="Shinystrap.Pages.Addons"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignWidth="695"
      Title="Addons"
      Loaded="Addons_OnLoaded">

    <Page.Resources>
        <ResourceDictionary>
            <StackPanel x:Key="DialogContent">
                <TextBlock Text="Are you sure you want to proceed?" TextWrapping="Wrap" />
                <CheckBox Content="Don't ask me again." />
            </StackPanel>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10,30,10,30" Background="Transparent">

            <TextBlock Text="Tracking" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />

            <ui:CardControl Margin="0,0,0,25">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="EyeTracking24" />
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Server Location" FontWeight="SemiBold" />
                        <TextBlock Text="When in-game, shows the server location." Foreground="White" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding IsActivityTrackingEnabled}" VerticalAlignment="Center"
                                 Checked="TrackServerLocation_OnChecked" Unchecked="TrackServerLocation_OnUnchecked" />
            </ui:CardControl>

            <TextBlock Text="Roblox Related" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />

            <ui:CardControl Margin="0,0,0,10">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="UninstallApp24" />
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Reinstall Roblox" FontWeight="SemiBold" />
                        <TextBlock Text="Installs Roblox freshly" Foreground="White" FontSize="12" TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button Content="ReInstall" Foreground="White" Click="ReInstall_Click" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,10">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="BookmarkMultiple16" />
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Multi-Instance" FontWeight="SemiBold" />
                        <TextBlock Text="Enables roblox to get opened by more than one account." Foreground="White"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="MutexSwitch" VerticalAlignment="Center" Checked="RbxMutex_OnChecked"
                                 Unchecked="RbxMutex_OnUnchecked" />
            </ui:CardControl>

            <Expander HorizontalContentAlignment="Stretch" Padding="16,12" Margin="0,0,0,25">
                <Expander.Header>
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="Live24"
                                       FontSize="24"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Channel" FontWeight="SemiBold" />
                            <TextBlock Text="Choose deployment channel." Foreground="White" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>

                        <TextBox Grid.Column="2" Width="198" Margin="20,0,35,0" VerticalAlignment="Center" />
                    </Grid>
                </Expander.Header>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock x:Name="CurrentChannel" VerticalAlignment="Center" Foreground="White" />
                </StackPanel>
            </Expander>

            <Expander HorizontalContentAlignment="Stretch" Padding="16,12" Margin="0,-15,0,25">
                <Expander.Header>
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="FastAcceleration24"
                                       FontSize="24"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Player Sniper" FontWeight="SemiBold" />
                            <TextBlock Text="Snipe a roblox player of your choice." Foreground="White" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Expander.Header>
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <TextBlock Text="Username:" VerticalAlignment="Center" Foreground="White" Width="80" />
                            <TextBox Width="200" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Place Id:" VerticalAlignment="Center" Foreground="White" Width="80" />
                            <TextBox Width="200" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Snipe" VerticalAlignment="Top" Margin="0,48,0,0"
                            HorizontalAlignment="Center" Width="93" />
                </Grid>
            </Expander>

            <TextBlock Text="Discord Related" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />

            <ui:CardControl>
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Drafts16" />
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Discord Rich Presence" FontWeight="SemiBold" />
                        <TextBlock Text="Shows on discord what you are playing." Foreground="White" FontSize="12"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch IsChecked="{Binding IsActivityTrackingEnabled}" VerticalAlignment="Center" />
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>