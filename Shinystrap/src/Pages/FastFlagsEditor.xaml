<Page x:Class="Shinystrap.Pages.FastFlagsEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignWidth="695"
      d:DesignHeight="470"
      Title="FastFlagsEditor">

    <Grid>
        <TextBlock Text="Fast Flags" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,18,0,0"/>
        <TextBlock Text="Edit your own FFlags, use at your own risk!" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,47,0,0"/>

        <ui:Button Content="Add"
           Icon="{ui:SymbolIcon Add24}"
           Padding="12,6"
           CommandParameter="{Binding}" Margin="12,68,0,0" VerticalAlignment="Top" Width="94" Click="AddFlag_Click"/>

        <ui:Button Content="Delete"
            Icon="{ui:SymbolIcon Delete24}"
            Padding="12,6"
            Appearance="Danger"
            CommandParameter="{Binding}" Margin="111,68,0,0" VerticalAlignment="Top" Width="123" Click="DeleteFlag_Click"/>
        <ui:Button Content="Export Json"
            Icon="{ui:SymbolIcon ArrowExportLtr24}"
            Padding="12,6"
            CommandParameter="{Binding}" Margin="239,68,0,0" VerticalAlignment="Top" Width="129" Click="Export_Click"/>
        <ui:Button Content="Import Json"
            Icon="{ui:SymbolIcon ArrowImport24}"
            Padding="12,6"
            CommandParameter="{Binding}" Margin="373,68,0,0" VerticalAlignment="Top" Width="129" Click="Import_Click"/>

        <ui:DataGrid x:Name="FlagsDataGrid" ItemsSource="{Binding Items}" Margin="10,106,10,10"
             AutoGenerateColumns="False"
             BorderThickness="1"
             BorderBrush="{DynamicResource ControlElevationBorderBrush}"
             CanUserAddRows="False"
             SelectionMode="Single">
            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="200"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
            </ui:DataGrid.Columns>
        </ui:DataGrid>
        <ui:Button Content="Save"
            Appearance="Info"
            Icon="{ui:SymbolIcon Save24}"
            Padding="12,6"
            CommandParameter="{Binding}" Margin="591,68,0,0" VerticalAlignment="Top" Width="94" Click="Save_Click"/>

    </Grid>
</Page>
