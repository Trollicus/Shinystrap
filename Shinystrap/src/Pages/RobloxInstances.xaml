<Page x:Class="Shinystrap.Pages.RobloxInstances"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignWidth="695"
      d:DesignHeight="470"
      Title="RobloxInstaces">

    <Page.Resources>

        <DataTemplate x:Key="InstanceCardTemplate">
            <ui:CardControl Margin="10,8,10,0" VerticalAlignment="Top">

                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32"
                    CornerRadius="16"
                    ClipToBounds="True"
                    Margin="0,0,12,0">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding ImageSource}"
                                Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}"
                           Foreground="White"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:CardControl.Header>

                <ui:Button Content="Disconnect"
                           Icon="{ui:SymbolIcon Dismiss24}"
                           Padding="12,6"
                           CommandParameter="{Binding}" Click="Disconnect_OnClick" />

            </ui:CardControl>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <TextBlock Text="Instances" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,18,0,0"/>
        <TextBlock Text="All currently opened Roblox Instances" Foreground="White" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,47,0,0"/>

        <ScrollViewer VerticalAlignment="Top"
                      Margin="10,68,10,0"
                      VerticalScrollBarVisibility="Auto" Height="392">
            <ItemsControl x:Name="InstancesLists"
                          ItemTemplate="{StaticResource InstanceCardTemplate}" />
        </ScrollViewer>

    </Grid>
</Page>