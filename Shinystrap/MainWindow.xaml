<ui:FluentWindow x:Class="Shinystrap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
        xmlns:pages1="clr-namespace:Shinystrap.Pages"
        mc:Ignorable="d"
        Title="Shinystrap"
        Height="520"
        Width="900"
        MaxHeight="520"
        MaxWidth="900"
        MinHeight="520"
        MinWidth="900"
        ui:ExtendsContentIntoTitleBar="True"
        ui:WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ResizeMode="NoResize"
        WindowStyle="None"
        Loaded="FluentWindow_Loaded"
        Closing="FluentWindow_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Padding="8" x:Name="TitleBar" Grid.Row="0" 
                     ForceShutdown="False" 
                     Title="Shinystrap" 
                     Height="38" CanMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/src/Handlers/Shinystrap/Shinystrap.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        
        <tray:NotifyIcon
            Grid.Row="0" x:Name="TrayIcon"
        TooltipText="Shinystrap"
        FocusOnLeftClick="True"
        MenuOnRightClick="True">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem Header="Open">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowCircleRight24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Quit" Click="TrayQuit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Power24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ui:NavigationView
                BorderThickness="0"
                x:Name="MainNavigation" 
                PaneDisplayMode="Left"
                IsPaneOpen="True"
                OpenPaneLength="190"
                CompactPaneLength="48"
                IsBackButtonVisible="Collapsed"
                IsPaneToggleVisible="False"
                IsFooterSeparatorVisible="False"
                IsTopSeparatorVisible="False"
                Margin="6,5,9,7"
                Grid.ColumnSpan="2">
                
                <ui:NavigationView.Resources>
                    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
                    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
                </ui:NavigationView.Resources>

                <ui:NavigationView.MenuItems>
                    
                    <ui:NavigationViewItem Content="Addons"
                                       TargetPageType="{x:Type pages1:Addons}">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Add28" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="Fast Flags"
                                TargetPageType="{x:Type pages1:FastFlagsEditor}">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Flag48" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="Game History"
                                TargetPageType="{x:Type pages1:GameHistory}">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="History28" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="Roblox Instances"
                                TargetPageType="{x:Type pages1:RobloxInstances}">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Key32" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>

                </ui:NavigationView.MenuItems>  

                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Content="Shinystrap" 
                                           Tag="Settings"
                                           TargetPageType="{x:Type pages1:Settings}">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>

            </ui:NavigationView>
        </Grid>
        <ui:SnackbarPresenter x:Name="SnackbarPresenter" Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Bottom" />
    </Grid>
</ui:FluentWindow>